# MediSense AI Server Environment Configuration
PROJECT_NAME="MediSense AI"
VERSION="1.0.0"
API_V1_STR="/api/v1"
DEBUG=True

# Server Host & Port
HOST="0.0.0.0"
PORT=8000

# Security & Secrets
SECRET_KEY="medisense-ai-super-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PostgreSQL Configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your_postgres_password"
POSTGRES_SERVER="127.0.0.1"
POSTGRES_PORT=5432
POSTGRES_DB="medisense_db"

# Database Connection URL (Note: encode special chars like '@' as '%40')
DATABASE_URL="postgresql://postgres:your_postgres_password@127.0.0.1:5432/medisense_db"

# Gemini AI API Key
GEMINI_API_KEY=""

# CORS Allowed Origins
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
